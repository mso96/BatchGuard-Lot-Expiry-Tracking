{
  "name": "batchguard-lot-expiry-tracking",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build": "remix vite:build",
    "dev": "remix vite:dev --host 127.0.0.1",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "start:prod": "prisma migrate deploy && remix-serve ./build/server/index.js",
    "start": "prisma migrate deploy && remix-serve ./build/server/index.js",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@remix-run/node": "^2.17.0",
    "@remix-run/react": "^2.17.0",
    "@remix-run/serve": "^2.17.0",
    "@shopify/app-bridge": "^3.7.10",
    "@shopify/polaris": "^12.27.0",
    "@shopify/shopify-app-remix": "^4.2.1",
    "@shopify/shopify-app-session-storage-prisma": "^9.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "isbot": "^5.1.25",
    "node-cron": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "wrangler": "^3.114.17"
  }
}
